                  "pm.test('댓글 등록 메시지', () => {",
                  "  const j = pm.response.json();",
                  "  pm.expect(j.message).to.include('댓글');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/comments",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"post_id\": {{postId}},\n  \"content\": \"테스트 댓글 내용입니다.\"\n}"
            }
          }
        },
        {
          "name": "[실패] 댓글 작성 - 내용 누락",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status: 400 Bad Request', () => pm.response.to.have.status(400));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/comments",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"post_id\": {{postId}},\n  \"content\": \"\"\n}"
            }
          }
        },
        {
          "name": "[실패] 댓글 작성 - 미인증 (로그아웃 후 시도)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status: 401 Unauthorized', () => pm.response.to.have.status(401));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/comments",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"post_id\": {{postId}},\n  \"content\": \"미인증 댓글 시도\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "🔓 로그아웃 (Logout)",
      "item": [
        {
          "name": "[성공] 로그아웃",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status: 200 OK', () => pm.response.to.have.status(200));",
                  "pm.test('로그아웃 메시지', () => {",
                  "  const j = pm.response.json();",
                  "  pm.expect(j.message).to.include('로그아웃');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/logout"
          }
        }
      ]
    }
  ]
}
